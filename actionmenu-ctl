#!/bin/bash
# ActionMenu control script
# Usage: actionmenu-ctl <open|close|toggle|select|status>

# Find the ActionRing install path
# Priority: ~/.config/ActionRing/config.jsonc > ACTIONMENU_PATH env var > script's own directory
get_install_path() {
    local config_file="$HOME/.config/ActionRing/config.jsonc"
    if [ -f "$config_file" ]; then
        local path
        path=$(grep -oP '"installPath"\s*:\s*"\K[^"]+' "$config_file" 2>/dev/null)
        if [ -n "$path" ]; then
            echo "$path"
            return
        fi
    fi
    if [ -n "$ACTIONMENU_PATH" ]; then
        echo "$ACTIONMENU_PATH"
        return
    fi
    echo "$(cd "$(dirname "$0")" && pwd)"
}

CONFIG_PATH="$(get_install_path)"

case "$1" in
    open)
        qs -p "$CONFIG_PATH" ipc call menu open
        ;;
    close)
        qs -p "$CONFIG_PATH" ipc call menu close
        ;;
    toggle)
        qs -p "$CONFIG_PATH" ipc call menu toggle
        ;;
    select)
        qs -p "$CONFIG_PATH" ipc call menu select
        ;;
    status)
        qs -p "$CONFIG_PATH" ipc call menu isOpen
        ;;
    *)
        echo "Usage: actionmenu-ctl <open|close|toggle|select|status>"
        exit 1
        ;;
esac
